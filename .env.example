# Bridge Server - Environment Config
# Rename this to .env or set these as system environment variables

# LM Studio local server URL
LM_STUDIO_URL=http://localhost:1234

# Default provider: local or openrouter
DEFAULT_PROVIDER=local

# Default local model name (must match what's loaded in LM Studio)
DEFAULT_MODEL=local-model

# Default OpenRouter model
DEFAULT_OPENROUTER_MODEL=openrouter/free

# Vision-capable OpenRouter model used automatically for image requests
OPENROUTER_VISION_MODEL=google/gemma-3-4b-it:free

# OpenRouter API configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_MODELS=openrouter/free
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_SITE_NAME=waBridge

# Bridge server port (must match extension's MCP_SERVER in background.js)
PORT=3000

# Path to Node.exe on Windows
NODE_BIN=C:\Program Files\nodejs\node.exe

# Base path for your MCP servers
MCP_BASE=C:\Users\XXX\AppData\Roaming\LM Studio\mcp

# file-reader: allowed directory
ALLOWED_DIR=C:\Users\XXX

# github-reader: your GitHub Personal Access Token
GITHUB_TOKEN=your_github_token_here
